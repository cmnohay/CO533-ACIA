import os
import json
from concurrent.futures import ThreadPoolExecutor
from dotenv import load_dotenv
from openai import OpenAI

# --- Setup ---
load_dotenv(override=True)

OPENAI_API_KEY = os.getenv("OPENAI_API_KEY")
if not OPENAI_API_KEY or OPENAI_API_KEY.strip().lower() in {"", "your_openai_api_key_here", "sk-your_key_here"}:
    raise ValueError("Set a valid OPENAI_API_KEY in .env before running Lab 02B.")

# Initialize the OpenAI client
client = OpenAI(
    api_key=OPENAI_API_KEY,
    base_url=os.getenv("OPENAI_BASE_URL") 
)

MODEL = os.getenv("OPENAI_MODEL", "gpt-5-nano")

def chat(messages: list[dict], temperature: float = 1.0):
    response = client.chat.completions.create(
        model=MODEL,
        messages=messages,
        temperature=temperature,
    )
    return response.choices[0].message.content

# Helper to prevent JSON crashes
def parse_json_safely(raw_str):
    clean = raw_str.strip().replace("```json", "").replace("```", "").strip()
    try: 
        return json.loads(clean)
    except: 
        return None

print(f"Using Model: {MODEL}")
print("--- Starting STRETCH GOAL: The Master Pipeline ---\n")

TOPIC = "Best practices for implementing RAG in enterprise apps"
print(f"Target Topic: '{TOPIC}'\n")

# ==========================================
# PHASE 1: ROUTING
# ==========================================
print("[Phase 1] Routing to the correct department...")
route_raw = chat([
    {"role": "system", "content": "Classify the topic as either 'technical' or 'business'. Reply with ONE word only. No punctuation."},
    {"role": "user", "content": TOPIC}
]).strip().lower()

category = "business" if "business" in route_raw else "technical"
print(f"  -> Routed to: {category.upper()} Pipeline\n")

# ==========================================
# PHASE 2: ORCHESTRATOR-WORKERS (Parallel Research)
# ==========================================
print("[Phase 2] Orchestrator planning research...")
plan_raw = chat([
    {"role": "system", "content": f"You are a {category} research director. Output a JSON array of exactly 2 strings (questions) to investigate this topic. ONLY return an array of strings. Example: [\"Q1\", \"Q2\"]"},
    {"role": "user", "content": TOPIC}
])

subtasks = parse_json_safely(plan_raw)
if not subtasks or not isinstance(subtasks, list): 
    subtasks = ["What is the main benefit?", "What are the key challenges?"] 

def worker_research(q):
    safe_q = str(q)
    print(f"    [Worker] Researching: {safe_q[:60]}...")
    return chat([
        {"role": "system", "content": f"You are a {category} expert. Answer concisely in 2 sentences."},
        {"role": "user", "content": safe_q}
    ])

# Run workers in parallel
with ThreadPoolExecutor(max_workers=2) as pool:
    results = list(pool.map(worker_research, subtasks))

research_data = "\n\n".join([f"Q: {q}\nA: {a}" for q, a in zip(subtasks, results)])
print("  -> Research complete.\n")

# ==========================================
# PHASE 3: EVALUATOR-OPTIMIZER (Draft & Refine)
# ==========================================
print("[Phase 3] Evaluator-Optimizer Drafting & Refining...")

def generate_draft(feedback=None):
    print("    [Writer] Generating draft...")
    msg = f"Write a 75-word {category} summary based on this data:\n{research_data}"
    if feedback:
        msg += f"\n\nImprove the draft based on this strict feedback: {feedback}"
    return chat([{"role": "user", "content": msg}])

def evaluate(draft):
    print("    [Editor] Grading draft...")
    raw = chat([
        {"role": "system", "content": "Score this draft out of 10 for clarity and professional tone. Return ONLY JSON: {\"score\": <int>, \"feedback\": \"<string>\"}"},
        {"role": "user", "content": draft}
    ])
    
    parsed = parse_json_safely(raw)
    if parsed and 'score' in parsed: 
        return parsed
    # Fallback if the model fails to format JSON properly
    return {"score": 10, "feedback": ""} 

current_draft = generate_draft()

for i in range(1, 4): # Max 3 iterations
    eval_result = evaluate(current_draft)
    score = eval_result.get('score', 0)
    print(f"    -> Iteration {i} Score: {score}/10")
    
    if score >= 8:
        print("    -> Quality threshold met!")
        break
    else:
        print(f"    -> Refining based on Editor feedback...")
        current_draft = generate_draft(eval_result.get('feedback'))

# ==========================================
# FINAL OUTPUT
# ==========================================
print("\n" + "="*50)
print(f"FINAL MASTERPIECE ({category.upper()}):\n\n{current_draft}")
print("="*50 + "\n")
