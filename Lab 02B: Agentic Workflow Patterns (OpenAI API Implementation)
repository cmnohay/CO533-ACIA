import os
from dotenv import load_dotenv
from openai import OpenAI

# --- Setup ---
load_dotenv(override=True)

OPENAI_API_KEY = os.getenv("OPENAI_API_KEY")
if not OPENAI_API_KEY or OPENAI_API_KEY.strip().lower() in {"", "your_openai_api_key_here", "sk-your_key_here"}:
    raise ValueError("Set a valid OPENAI_API_KEY in .env before running Lab 02B.")

# Initialize the OpenAI client
client = OpenAI(
    api_key=OPENAI_API_KEY,
    base_url=os.getenv("OPENAI_BASE_URL") 
)

MODEL = os.getenv("OPENAI_MODEL", "gpt-5-nano")

def chat(messages: list[dict], temperature: float = 1):
    response = client.chat.completions.create(
        model=MODEL,
        messages=messages,
        temperature=temperature,
    )
    return response.choices[0].message.content

TOPIC = "Why vector databases matter for RAG applications"

# --- Exercise 1: Prompt Chaining with Retry + Gate ---

outline = ""
success = False
max_retries = 2

print(f"Using Model: {MODEL}")
print("--- Starting Pattern 1: Prompt Chaining (with Gate) ---")

for attempt in range(max_retries + 1):
    print(f"\n[Attempt {attempt + 1}] Generating Outline...")
    
    # THE FIX: Removed the temperature override here so it defaults to 1
    outline = chat([
        {"role": "system", "content": "You are a technical strategist. Output exactly 3 numbered sections (1., 2., 3.) with titles only. No intro/outro."},
        {"role": "user", "content": f"Topic: {TOPIC}"},
    ])
    
    # --- The Gate: Enforce strict format ---
    has_1 = "1." in outline
    has_2 = "2." in outline
    has_3 = "3." in outline
    gate_pass = has_1 and has_2 and has_3 and len(outline) > 30

    if gate_pass:
        print(f"✅ Gate Passed on attempt {attempt + 1}!")
        success = True
        break
    else:
        print(f"❌ Gate Failed: Outline format was incorrect.")

if not success:
    print("Stopping: Could not generate a valid outline after maximum retries.")
else:
    # --- Step 2: Draft (Only runs if Gate passed) ---
    print("\n[Step 2] Expanding into Draft...")
    draft = chat([
        {"role": "system", "content": "You are a senior technical writer. Write a 100-word draft based on the outline."},
        {"role": "user", "content": f"Outline:\n{outline}"},
    ])
    print(f"DONE.\nDraft:\n{draft}")

    # --- Step 3: Polish ---
    print("\n[Step 3] Polishing...")
    polished = chat([
        {"role": "system", "content": "Simplify this for a non-technical audience. Keep it under 50 words."},
        {"role": "user", "content": draft},
    ])
    print(f"DONE.\nFinal Polished Result:\n{polished}")

print("\n--- Pipeline Complete ---")

