import os
import json
from concurrent.futures import ThreadPoolExecutor
from dotenv import load_dotenv
from openai import OpenAI

# --- Setup ---
load_dotenv(override=True)

OPENAI_API_KEY = os.getenv("OPENAI_API_KEY")
if not OPENAI_API_KEY or OPENAI_API_KEY.strip().lower() in {"", "your_openai_api_key_here", "sk-your_key_here"}:
    raise ValueError("Set a valid OPENAI_API_KEY in .env before running Lab 02B.")

# Initialize the OpenAI client
client = OpenAI(
    api_key=OPENAI_API_KEY,
    base_url=os.getenv("OPENAI_BASE_URL") 
)

MODEL = os.getenv("OPENAI_MODEL", "gpt-5-nano:")

def chat(messages: list[dict], temperature: float = 1.0):
    response = client.chat.completions.create(
        model=MODEL,
        messages=messages,
        temperature=temperature,
    )
    return response.choices[0].message.content

print(f"Using Model: {MODEL}")
print("--- Starting Pattern 4: Orchestrator-Workers (Dynamic Depth) ---\n")

# --- Exercise 4 Logic ---

RESEARCH_GOAL = "Explain how Retrieval-Augmented Generation (RAG) works."
all_qa_history = ""

# Helper to clean JSON and prevent crashes
def parse_json_safely(raw_str):
    clean = raw_str.strip().replace("```json", "").replace("```", "").strip()
    try:
        return json.loads(clean)
    except:
        return None

def worker_answer(question: str) -> str:
    # Ensure the question is a string to avoid API errors
    safe_q = str(question)
    print(f"    [Worker] Researching: '{safe_q[:60]}...'")
    return chat([
        {"role": "system", "content": "You are a concise AI/ML expert. Answer in 2 sentences max."},
        {"role": "user", "content": safe_q},
    ])

# ==========================================
# ROUND 1: Initial Sub-tasks
# ==========================================
print("[Round 1] Orchestrator breaking down the goal...")
plan_raw = chat([
    {"role": "system", "content": "You are a research orchestrator. Output a JSON array of exactly 2 strings representing focused sub-questions to investigate the goal. ONLY return an array of strings. Example: [\"Q1\", \"Q2\"]"},
    {"role": "user", "content": RESEARCH_GOAL},
])

subtasks_r1 = parse_json_safely(plan_raw)
# Fallback in case of a JSON error
if not subtasks_r1 or not isinstance(subtasks_r1, list):
    subtasks_r1 = ["What is the retrieval step in RAG?", "What is the generation step in RAG?"]

# Run Round 1 Workers in Parallel
with ThreadPoolExecutor(max_workers=2) as pool:
    results_r1 = list(pool.map(worker_answer, subtasks_r1))

for q, a in zip(subtasks_r1, results_r1):
    all_qa_history += f"Q: {q}\nA: {a}\n\n"

# ==========================================
# DYNAMIC DEPTH CHECK (The new requirement)
# ==========================================
print("\n[Decision] Orchestrator deciding if deeper research is needed...")
decision_raw = chat([
    {"role": "system", "content": (
        "Read the Q&A history. Do we need 1 more deeper, advanced sub-question to fully explain the topic? "
        "Output JSON ONLY: {\"needs_more\": true, \"new_question\": \"<string>\"} or {\"needs_more\": false, \"new_question\": \"\"}"
    )},
    {"role": "user", "content": f"Goal: {RESEARCH_GOAL}\n\nCurrent History:\n{all_qa_history}"},
])

decision = parse_json_safely(decision_raw) or {"needs_more": False}

# ==========================================
# ROUND 2 (Conditional)
# ==========================================
if decision.get("needs_more") and decision.get("new_question"):
    new_q = str(decision["new_question"])
    print(f"[Round 2] YES. Deeper question triggered:\n    -> '{new_q}'")
    
    new_a = worker_answer(new_q)
    all_qa_history += f"Q: {new_q}\nA: {new_a}\n\n"
else:
    print("[Round 2] NO. Current information is sufficient.")

# ==========================================
# FINAL SYNTHESIS
# ==========================================
print("\n[Final] Synthesizing report...")
final_report = chat([
    {"role": "system", "content": "Synthesize the provided Q&A pairs into a smooth 100-word technical summary."},
    {"role": "user", "content": f"Goal: {RESEARCH_GOAL}\n\nData:\n{all_qa_history}"},
])

print("\n" + "="*50)
print(f"FINAL SYNTHESIZED REPORT:\n\n{final_report}")
print("="*50 + "\n")

