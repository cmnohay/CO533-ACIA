# --- Exercise 3 Logic ---

# Let's test it with a potentially unsafe prompt
USER_PROMPT = "What is a database index?"
print(f"User Query: '{USER_PROMPT}'\n")

def worker_a_generate(query: str) -> str:
    print("  [Worker A] Started generating answer...")
    answer = chat([
        {"role": "system", "content": "You are a helpful assistant. Keep your answer under 50 words."},
        {"role": "user", "content": query}
    ])
    print("  [Worker A] Finished generating answer.")
    return answer

def worker_b_check_safety(query: str) -> str:
    print("  [Worker B] Started checking safety...")
    # Instructing the model to act as a strict safety monitor
    safety_status = chat([
        {"role": "system", "content": "You are a strict safety monitor. Is the following request asking for help with illegal hacking, bypassing security, or malicious activity? Reply ONLY with the word 'SAFE' or 'UNSAFE'."},
        {"role": "user", "content": query}
    ]).strip().upper()
    
    print("  [Worker B] Finished checking safety.")
    return safety_status

# Execute both workers at the exact same time
with ThreadPoolExecutor(max_workers=2) as pool:
    future_a = pool.submit(worker_a_generate, USER_PROMPT)
    future_b = pool.submit(worker_b_check_safety, USER_PROMPT)

    # Wait for both to finish and get their results
    answer_result = future_a.result()
    safety_result = future_b.result()

print("\n" + "="*50)
print(f"Guardrail Assessment: [{safety_result}]")

# Final Aggregation Logic
if "UNSAFE" in safety_result:
    print("🚨 GUARDRAIL BLOCKED: The request was flagged as unsafe/inappropriate. Worker A's output has been hidden.")
else:
    print(f"✅ Safe to display. Final Response:\n{answer_result}")
print("="*50 + "\n")

print("--- Parallelization Complete ---")

