    raise ValueError("Set a valid OPENAI_API_KEY in .env before running Lab 02B.")

# Initialize the OpenAI client
client = OpenAI(
    api_key=OPENAI_API_KEY,
    base_url=os.getenv("OPENAI_BASE_URL") 
)

MODEL = os.getenv("OPENAI_MODEL", "gpt-5-nano")

def chat(messages: list[dict], temperature: float = 1):
    response = client.chat.completions.create(
        model=MODEL,
        messages=messages,
        temperature=temperature,
    )
    return response.choices[0].message.content

print(f"Using Model: {MODEL}")
print("--- Starting Pattern 2: Routing (with Feature Request) ---\n")

# --- Exercise 2 Logic ---

SPECIALIST_PROMPTS = {
    "billing": "You are a billing support specialist. Be empathetic and solution-focused. Keep it under 50 words.",
    "technical": "You are a senior technical support engineer. Give precise, step-by-step answers. Keep it under 50 words.",
    "general": "You are a friendly customer success agent. Be warm and concise. Keep it under 50 words.",
    "feature_request": "You are a Product Manager. Acknowledge the user's idea, explain that you will add it to the product roadmap review, and thank them. Keep it under 50 words."
}

def classify_query(user_query: str) -> str:
    """Return one of: billing | technical | general | feature_request"""
    result = chat([
        {"role": "system", "content": (
            "Classify the following customer query into exactly one category: "
            "billing, technical, general, or feature_request. "
            "Reply with the single word only. Do not add punctuation."
        )},
        {"role": "user", "content": user_query},
    ]).strip().lower()
    
    for key in SPECIALIST_PROMPTS:
        if key in result:
            return key
    return "general"

def routed_response(user_query: str) -> tuple[str, str]:
    print(f"Processing Query: '{user_query}'")
    
    category = classify_query(user_query)
    print(f"  -> Routed to: [{category.upper()}]")
    
    system_prompt = SPECIALIST_PROMPTS[category]
    answer = chat([
        {"role": "system", "content": system_prompt},
        {"role": "user", "content": user_query},
    ])
    return category, answer

# --- Test Queries (Updated to perfectly match the lab instructions) ---
queries = [
    # The 3 Original Queries
    "I was charged twice on my last invoice.",
    "My API requests keep returning a 429 error even though I'm below the limit.",
    "What are your business hours?",
    # The 2 New Feature Request Queries
    "Can you add a dark mode to the dashboard? It hurts my eyes at night.",
    "It would be great if the app could export reports to PDF, not just CSV."
]

for q in queries:
    category, answer = routed_response(q)
    print(f"  -> Response:\n{answer}\n{'-'*50}\n")

print("--- Routing Complete ---")

