import os
import json
from dotenv import load_dotenv
from openai import OpenAI

# --- Setup ---
load_dotenv(override=True)

OPENAI_API_KEY = os.getenv("OPENAI_API_KEY")
if not OPENAI_API_KEY or OPENAI_API_KEY.strip().lower() in {"", "your_openai_api_key_here", "sk-your_key_here"}:
    raise ValueError("Set a valid OPENAI_API_KEY in .env before running Lab 02B.")

# Initialize the OpenAI client
client = OpenAI(
    api_key=OPENAI_API_KEY,
    base_url=os.getenv("OPENAI_BASE_URL") 
)

MODEL = os.getenv("OPENAI_MODEL", "gpt-5-nano")

def chat(messages: list[dict], temperature: float = 1.0):
    response = client.chat.completions.create(
        model=MODEL,
        messages=messages,
        temperature=temperature,
    )
    return response.choices[0].message.content

print(f"Using Model: {MODEL}")
print("--- Starting Pattern 5: Evaluator-Optimizer (Custom Rubric) ---\n")

# --- Exercise 5 Logic ---

WRITING_TASK = "Explain what an 'API' is using a restaurant analogy. Target audience: Non-technical beginners."
MAX_ITERATIONS = 4

def generate_draft(task: str, feedback: str = None) -> str:
    print("  [Writer] Writing draft...")
    messages = [
        {"role": "system", "content": "You are a technical educator. Write clearly and concisely (max 50 words)."},
        {"role": "user", "content": task},
    ]
    if feedback:
        messages.append({"role": "user", "content": f"Improve your previous response based on this strict feedback:\n{feedback}"})
    
    return chat(messages)

def evaluate_draft(task: str, draft: str) -> dict:
    print("  [Editor] Evaluating draft...")
    prompt = (
        "You are a strict editor. Evaluate the draft on three axes (1-10): "
        "clarity (is it easy to understand?), accuracy (is the technical analogy correct?), and brevity (is it short?). "
        "Return ONLY valid JSON in this format: {\"clarity\": <int>, \"accuracy\": <int>, \"brevity\": <int>, \"feedback\": \"<string>\"}"
    )
    
    raw_eval = chat([
        {"role": "system", "content": prompt},
        {"role": "user", "content": f"Task: {task}\n\nDraft to evaluate:\n{draft}"}
    ])
    
    # Clean up markdown JSON formatting securely
    clean_eval = raw_eval.strip().replace("```json", "").replace("```", "").strip()
    
    try:
        return json.loads(clean_eval)
    except Exception as e:
        print(f"  [Error] Failed to parse JSON: {clean_eval}")
        return {"clarity": 0, "accuracy": 0, "brevity": 0, "feedback": "System error: Failed to parse evaluation."}

# ==========================================
# THE OPTIMIZATION LOOP
# ==========================================
feedback_history = None

for iteration in range(1, MAX_ITERATIONS + 1):
    print(f"\n--- Iteration {iteration} ---")
    
    # 1. Generate Draft
    current_draft = generate_draft(WRITING_TASK, feedback_history)
    print(f"\nDraft:\n{current_draft}\n")
    
    # 2. Evaluate Draft
    evaluation = evaluate_draft(WRITING_TASK, current_draft)
    c, a, b = evaluation.get('clarity', 0), evaluation.get('accuracy', 0), evaluation.get('brevity', 0)
    
    print(f"Scores -> Clarity: {c}/10 | Accuracy: {a}/10 | Brevity: {b}/10")
    print(f"Feedback: {evaluation.get('feedback', 'None')}")
    
    # 3. Check Condition (All must be >= 7)
    if c >= 7 and a >= 7 and b >= 7:
        print(f"\n✅ SUCCESS: All targets met on Iteration {iteration}!")
        print("="*50)
        print(f"FINAL APPROVED DRAFT:\n{current_draft}")
        print("="*50)
        break
    else:
        print("\n⚠️ Targets not met. Passing feedback to Writer for next iteration...")
        feedback_history = evaluation.get('feedback')

else:
    # This runs if the loop exhausts all MAX_ITERATIONS without breaking
    print(f"\n❌ Reached max iterations ({MAX_ITERATIONS}) without meeting all criteria.")
    print(f"Best effort:\n{current_draft}")

